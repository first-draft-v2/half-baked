---
layout: base.njk
---

<article class="media-review">
  <p class="media-review-eyebrow">
    {{ extractDate({date_finished: date_finished, date_watched: date_watched, date: page.date }) | date("MMM d, yyyy") }}
  </p>

  <h1 class="media-review-title">{{ title }}</h1>

  {% if rating %}
    <div class="media-review-rating" title="{{ rating }}/10">
      {% set fullStars = (rating / 2) | round(0, "floor") %}
      {% set halfStar = (rating % 2) >= 1 %}

      {% for i in range(0, 5) %}
        {% if i < fullStars %}
          <span class="star star-full">★</span>
        {% elif i == fullStars and halfStar %}
          <span class="star star-half">★</span>
        {% else %}
          <span class="star star-empty">☆</span>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}

  <div class="media-review-body">
    {{ content | safe }}
  </div>

  {% if tags %}
    <div class="media-review-tags">
      {% for tag in tags %}
        {% if tag != "post" %}
          <a href="{{ ('/tags/' + tag + '/') | url }}">#{{ tag }}</a>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</article>