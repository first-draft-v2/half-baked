<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} — {% endif %}Half-baked</title>
  <meta name="description" content="{{ description or 'Short poems and stories.' }}">
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
</head>
<body>
  <header class="site-header">
    <div class="wrap">
      <a class="site-title" href="{{ '/' | url }}">Half-baked</a>
      <nav class="site-nav">
        <a href="{{ '/' | url }}" class="{% if page.url == '/' %}active{% endif %}">Home</a>
        <a href="{{ '/posts/' | url }}" class="{% if page.url == '/posts/' %}active{% endif %}">Posts</a>
        <a href="{{ '/about/' | url }}" class="{% if page.url == '/about/' %}active{% endif %}">About</a>
        <a href="{{ '/tags/' | url }}" class="{% if page.url == '/tags/' %}active{% endif %}">Tags</a>
      </nav>
    </div>
  </header>

  <main class="wrap">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="wrap">
      &copy; {{ currentYear }} Half-baked
    </div>
  </footer>
</body>
</html>
