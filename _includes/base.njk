<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} — {% endif %}Half-baked</title>
  <meta name="description" content="{{ description or 'Short poems and stories.' }}">
  <link rel="icon" type="image/png" sizes="32x32" href="{{ '/favicon.png' | url }}">
  <link rel="apple-touch-icon" sizes="180x180" href="{{ '/apple-touch-icon.png' | url }}">
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
  <script src="{{ '/js/site.js' | url }}" defer></script>
</head>
<body>
  <header class="site-header">
    <div class="wrap">
      {% set _title = 'Halfbakken' if tags and tags.includes('dutch') else 'Half-baked' %}
      <div class="site-brand">
        <a class="site-title" href="{{ '/' | url }}">{{ _title }}</a>
        <span class="site-subtitle">A public archive of private thoughts.</span>
      </div>

      <nav class="site-nav">
        <a href="{{ '/' | url }}" class="{% if page.url == '/' or page.url.startsWith('/page/') %}active{% endif %}">Home</a>
        <a href="{{ '/posts/' | url }}" class="{% if page.url == '/posts/' or page.url.startsWith('/posts/page/') %}active{% endif %}">Posts</a>
        <a href="{{ '/lists/' | url }}" class="{% if page.url == '/lists/' %}active{% endif %}">Lists</a>
        <a href="{{ '/about/' | url }}" class="{% if page.url == '/about/' %}active{% endif %}">About</a>
        <a href="{{ '/tags/' | url }}" class="{% if page.url == '/tags/' %}active{% endif %}">Tags</a>
      </nav>
    </div>
  </header>

  <main class="wrap">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="wrap">
      &copy; {{ currentYear }} Half-baked
    </div>
  </footer>
</body>
</html>
