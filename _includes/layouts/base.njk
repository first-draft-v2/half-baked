<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{{ title | default(site.title | default("My Eleventy Blog")) }}</title>
  <link rel="alternate" type="application/rss+xml" title="{{ site.title }}" href="{{ site.url }}/feed.xml" />
  <style>
    body { font-family: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial; max-width: 800px; margin: 2rem auto; padding: 0 1rem; line-height: 1.6; }
    header a { text-decoration: none; color: inherit; }
    footer { margin-top: 3rem; color: #666; font-size: 0.9rem; }
  </style>
</head>
<body>
  <header>
    <h1><a href="/">{{ title | default(site.title | default("My Eleventy Blog")) }}</a></h1>
    <hr/>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer>
    <hr/>
    <p>Built with Eleventy</p>
  </footer>
</body>
</html>
