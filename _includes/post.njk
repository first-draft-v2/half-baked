---
layout: base.njk
---
{% set postType = "post" %}
{% if tags and "poetry" in tags %}
  {% set postType = "poem" %}
{% elseif tags and "misc" in tags %}
  {% set postType = "misc" %}
{% endif %}
<article class="post post--{{ postType }}">
  <div class="post-card-meta">
    <span class="post-kind">{{ postType }}</span>
    <time datetime="{{ page.date | date('yyyy-MM-dd') }}">{{ page | extractDate | date("MMM d, yyyy") }}</time>
  </div>
  <h1 class="post-title">{{ title }}</h1>

  {% if image %}
    <img class="post-image" src="{{ image | url }}" alt="{{ imageAlt or '' }}">
  {% endif %}

  <div class="post-body">
    {{ content | safe }}
  </div>

  {% if tags %}
    <div class="post-tags">
      {% for tag in tags %}
        {% if tag != "post" %}<a href="{{ ('/tags/#tag-' + tag) | url }}">#{{ tag }}</a>{% endif %}
      {% endfor %}
    </div>
  {% endif %}
</article>
