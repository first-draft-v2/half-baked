---
layout: base.njk
---
<article class="post">
  <p class="post-eyebrow">{{ page | extractDate | date("MMM d, yyyy") }}</p>
  <h1 class="post-title">{{ title }}</h1>

  {% if image %}
    <img class="post-image" src="{{ image | url }}" alt="{{ imageAlt or '' }}">
  {% endif %}

  <div class="post-body">
    {{ content | safe }}
  </div>

  {% if tags %}
    <div class="post-tags">
      {% for tag in tags %}
        {% if tag != "post" %}<a href="{{ ('/tags/' + tag + '/') | url }}">#{{ tag }}</a>{% endif %}
      {% endfor %}
    </div>
  {% endif %}
</article>
