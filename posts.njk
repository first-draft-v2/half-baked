---
layout: base.njk
title: Posts
pagination:
  data: collections.feedPosts
  size: 25
  alias: posts
permalink: "{% if pagination.pageNumber == 0 %}/posts/{% else %}/posts/page/{{ pagination.pageNumber + 1 }}/{% endif %}"
---
<div class="post-list">
  <header class="archive-header">
    <h1>Posts</h1>
    <p>Poems, notes, reviews, and other half-baked thoughts.</p>
  </header>

  <ol reversed>
    {% set previousYear = null %}
    {% set archiveStarted = false %}
    {% for post in posts %}
      {% if post.content %}
        {% set postYear = post | extractDate | date("yyyy") %}
        {% if previousYear and postYear != previousYear %}
          <li class="year-separator{% if not archiveStarted %} year-separator--archive{% endif %}">
            {% if not archiveStarted %}
              <span>{{ postYear }}</span>
              {% set archiveStarted = true %}
            {% else %}
              <span>{{ postYear }}</span>
            {% endif %}
          </li>
        {% endif %}
        {% set postType = "post" %}
        {% if post.data.tags and "reviews" in post.data.tags %}
          {% set postType = "review" %}
        {% elseif post.data.tags and "poetry" in post.data.tags %}
          {% set postType = "poem" %}
        {% elseif post.data.tags and "misc" in post.data.tags %}
          {% set postType = "misc" %}
        {% endif %}
        <li class="post-list-item--{{ postType }}">
          <a href="{{ post.url | url }}">
            <span class="post-list-date">{{ post | extractDate | date("MMM dd, yyyy") }}</span>
            <span class="post-list-title">{{ post.data.title }}</span>
            <span class="post-list-kind">{{ postType }}</span>
          </a>
        </li>
        {% set previousYear = postYear %}
      {% endif %}
    {% endfor %}
  </ol>
</div>
{% include "pagination.njk" %}
