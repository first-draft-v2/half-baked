---
layout: base.njk
title: Posts
permalink: /posts/
---
<div class="post-list">
  <ol reversed>
    {% for post in collections.post | reverse %}
      <li>
        <a href="{{ post.url | url }}">
          <span class="post-list-date">{{ post.date | date("MMM d") }}</span>
          <span class="post-list-title">{{ post.data.title }}</span>
        </a>
      </li>
    {% endfor %}
  </ol>
</div>
