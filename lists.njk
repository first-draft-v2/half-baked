---
layout: base.njk
title: Lists
permalink: /lists/
---

<div class="list-directory">
  <header class="archive-header">
    <h1>Lists</h1>
    <p>Reviews, ratings, rankings and collections.</p>
  </header>

  <ul>
    {% for item in collections.lists | sort(false, false, "data.listOrder") %}
      {% if not item.data.listHidden %}
        <li>
          <a href="{{ item.url | url }}">
            <span class="list-directory-title">
              <span class="list-directory-emoji" aria-hidden="true">{{ item.data.listEmoji }}</span>
              <span>{{ item.data.listLabel }}</span>
              <span class="list-directory-count">({% if item.data.listCollection == 'recipes' %}2{% else %}{{ collections[item.data.listCollection] | length }}{% endif %})</span>
            </span>
            <span class="list-directory-arrow" aria-hidden="true">→</span>
          </a>
        </li>
      {% endif %}
    {% endfor %}
  </ul>
</div>
