---
layout: base.njk
title: Lists
permalink: /lists/
---

<div class="list-directory">
  <header class="archive-header">
    <h1>Lists</h1>
    <p>Books, films, and series—finished, watched, and occasionally reviewed.</p>
  </header>

  <ul>
    {% for item in collections.lists %}
      <li>
        <a href="{{ item.url | url }}">
          <span class="list-directory-title">{{ item.data.title }}</span>
          <span class="list-directory-arrow" aria-hidden="true">→</span>
        </a>
      </li>
    {% endfor %}
  </ul>
</div>
