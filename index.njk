---
layout: base.njk
---
<div class="post-stack">
  {% set previousYear = null %}
  {% set archiveStarted = false %}
  {% for post in collections.posts | sortByLastDate %}
    {% if post.content %}
      {% set postYear = post | extractDate | date("yyyy") %}
      {% if previousYear and postYear != previousYear %}
        {% if not archiveStarted %}
          <div class="archive-notice">
            <span aria-hidden="true">🕷️</span><strong>Beware: Old Content Below</strong><span aria-hidden="true">🕷️</span>
          </div>
          {% set archiveStarted = true %}
        {% endif %}
        <div class="year-separator">
          <span>{{ postYear }}</span>
        </div>
      {% endif %}
      {% set postType = "post" %}
      {% if post.data.tags and "reviews" in post.data.tags %}
        {% set postType = "review" %}
      {% elseif post.data.tags and "poetry" in post.data.tags %}
        {% set postType = "poem" %}
      {% elseif post.data.tags and "misc" in post.data.tags %}
        {% set postType = "misc" %}
      {% endif %}
      <article class="post-card post-card--{{ postType }}">
        <div class="post-card-meta">
          <span class="post-kind">{{ postType }}</span>
          <time datetime="{{ post.date | date('yyyy-MM-dd') }}">{{ post | extractDate | date("MMM d, yyyy") }}</time>
        </div>
        <h2 class="post-title"><a href="{{ post.url | url }}">{{ post.data.title }}</a></h2>
        {% if post.data.image %}
          <img class="post-image" src="{{ post.data.image | url }}" alt="{{ post.data.imageAlt or '' }}">
        {% endif %}
        <div class="post-body">{{ post.templateContent | safe }}</div>
        {% if post.data.tags %}
          <div class="post-tags">
            {% for tag in post.data.tags %}
              {% if tag != "post" %}<a href="{{ ('/tags/#tag-' + tag) | url }}">#{{ tag }}</a>{% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </article>
      {% set previousYear = postYear %}
    {% endif %}
  {% endfor %}
</div>
