---
layout: base.njk
title: 📖 Books
permalink: /lists/books/
listOrder: 1
listEmoji: 📖
listLabel: Books
listCollection: books
tags:
  - lists
---

<div class="media-index" data-review-list data-page-size="30">
  <header class="archive-header">
    <h1>📖 Books</h1>
  </header>

  <table class="media-list">
    <thead>
        <tr>
            <th><button type="button" data-sort-key="title">Title <span class="sort-chevron" aria-hidden="true"></span></button></th>
            <th aria-sort="descending"><button type="button" data-sort-key="date">Finished/Added <span class="sort-chevron" aria-hidden="true">▾</span></button></th>
            <th><button type="button" data-sort-key="rating">Rating <span class="sort-chevron" aria-hidden="true"></span></button></th>
        </tr>
    </thead>

    <tbody>
        {% for item in collections.books | sortByLastDate %}
        <tr data-title="{{ item.data.title | lower | escape }}" data-date="{{ (item.data.date_finished or item.data.date_started or item.data.date_added or item.date) | date('yyyy-MM-dd') }}" data-rating="{{ item.data.rating or 0 }}">
            <td class="media-list-title">
                <a href="{{ item.url | url }}">
                    {{ item.data.title }}
                </a>
            </td>

            <td>
                {% set displayDate = item.data.date_finished or item.data.date_added %}
                {% if displayDate %}
                    <time datetime="{{ displayDate | date('yyyy-MM-dd') }}">
                        {{ displayDate | date("MM/dd/yyyy") }}
                    </time>
                    {% if not item.data.date_finished %}<span class="media-list-date-kind">added</span>{% endif %}
                {% endif %}
            </td>

            <td class="media-list-rating">
                {% if item.data.rating %}
                    <span class="rating" data-rating-label="{{ item.data.rating }}/10" aria-label="Rating: {{ item.data.rating }} out of 10" tabindex="0">
                        {% set fullStars = (item.data.rating / 2) | round(0, "floor") %}
                        {% set halfStar = (item.data.rating % 2) >= 1 %}

                        {% for i in range(0, 5) %}
                            {% if i < fullStars %}
                                <span class="star star-full">★</span>
                            {% elif i == fullStars and halfStar %}
                                <span class="star star-half">★</span>
                            {% else %}
                                <span class="star star-empty">☆</span>
                            {% endif %}
                        {% endfor %}
                    </span>
                {% endif %}
            </td>
            
        </tr>
        {% endfor %}
    </tbody>
  </table>
  <div class="list-pagination" data-list-pagination></div>
</div>
