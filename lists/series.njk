---
layout: base.njk
title: 📺 TV Series
permalink: /lists/tv/
listOrder: 3
listEmoji: 📺
listLabel: TV Series
listCollection: series
tags:
    - lists
---

<div class="media-index" data-review-list data-page-size="30">
  <header class="archive-header">
    <h1>📺 TV Series</h1>
  </header>

  <table class="media-list">
    <thead>
        <tr>
            <th><button type="button" data-sort-key="title">Title <span class="sort-chevron" aria-hidden="true"></span></button></th>
            <th><button type="button" data-sort-key="started">Started <span class="sort-chevron" aria-hidden="true"></span></button></th>
            <th aria-sort="descending"><button type="button" data-sort-key="finished">Finished <span class="sort-chevron" aria-hidden="true">▾</span></button></th>
            <th><button type="button" data-sort-key="rating">Rating <span class="sort-chevron" aria-hidden="true"></span></button></th>
        </tr>
    </thead>

    <tbody>
        {% for item in collections.series %}
        <tr data-title="{{ item.data.title | lower | escape }}" data-started="{% if item.data.date_started %}{{ item.data.date_started | date('yyyy-MM-dd') }}{% endif %}" data-finished="{% if item.data.date_finished %}{{ item.data.date_finished | date('yyyy-MM-dd') }}{% endif %}" data-rating="{{ item.data.rating or 0 }}">
            <td class="media-list-title">
                <a href="{{ item.url | url }}">
                    {{ item.data.title }}
                </a>
            </td>

            <td>
                {% if item.data.date_started %}
                    <time datetime="{{ item.data.date_started | date('yyyy-MM-dd') }}">
                        {{ item.data.date_started | date("MMM d, yyyy") }}
                    </time>
                {% endif %}
            </td>

            <td>
                {% if item.data.date_finished %}
                    <time datetime="{{ item.data.date_finished | date('yyyy-MM-dd') }}">
                        {{ item.data.date_finished | date("MMM d, yyyy") }}
                    </time>
                {% endif %}
            </td>

            <td class="media-list-rating">
                {% if item.data.rating %}
                    {{ item.data.rating }}/10
                {% endif %}
            </td>
        </tr>
        {% endfor %}
    </tbody>
  </table>
  <div class="list-pagination" data-list-pagination></div>
</div>
