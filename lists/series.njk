---
layout: base.njk
title: 📺 TV Series
permalink: /lists/tv/
listOrder: 3
listEmoji: 📺
listLabel: TV Series
listCollection: series
tags:
    - lists
---

<div class="media-index" data-review-list data-page-size="30">
  <header class="archive-header">
    <h1>📺 TV Series</h1>
  </header>

  {% include "review-list-controls.njk" %}

  <table class="media-list">
    <thead>
        <tr>
            <th>Title</th>
            <th>Started</th>
            <th>Finished</th>
            <th>Rating</th>
        </tr>
    </thead>

    <tbody>
        {% for item in collections.series %}
        <tr data-title="{{ item.data.title | lower | escape }}" data-date="{{ (item.data.date_finished or item.data.date_started or item.data.date_added or item.date) | date('yyyy-MM-dd') }}" data-rating="{{ item.data.rating or 0 }}">
            <td class="media-list-title">
                <a href="{{ item.url | url }}">
                    {{ item.data.title }}
                </a>
            </td>

            <td>
                {% if item.data.date_started %}
                    <time datetime="{{ item.data.date_started | date('yyyy-MM-dd') }}">
                        {{ item.data.date_started | date("MMM d, yyyy") }}
                    </time>
                {% endif %}
            </td>

            <td>
                {% if item.data.date_finished %}
                    <time datetime="{{ item.data.date_finished | date('yyyy-MM-dd') }}">
                        {{ item.data.date_finished | date("MMM d, yyyy") }}
                    </time>
                {% endif %}
            </td>

            <td class="media-list-rating">
                {% if item.data.rating %}
                    {{ item.data.rating }}/10
                {% endif %}
            </td>
        </tr>
        {% endfor %}
    </tbody>
  </table>
  <div class="list-pagination" data-list-pagination></div>
</div>
